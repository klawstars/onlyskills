      <span>OnlySkills</span>
    </div>
    {% if properties.title %}
    <h2 class="ux-f-title" data-aos="fade-up">{{ properties.title | renderString }}</h2>
    {% endif %}
    {% if properties.subtitle %}
    <p class="ux-f-subtitle" data-aos="fade-up">{{ properties.subtitle | renderString }}</p>
    {% endif %}
    <div class="ux-f-grid">
      <div class="ux-f-card ux-f-card-sm">
        <div class="ux-f-card-visual">
          <img src="https://i.imgur.com/sPDdCze.png" alt="Globe" style="width: 100%; height: 100%; object-fit: cover;">
        </div>
        <div class="ux-f-card-info">
          <div class="ux-f-card-info-title">Customers around the world</div>
          <div class="ux-f-card-info-desc">Users all over the world using our cheats.</div>
        </div>
      </div>
      <div class="ux-f-card ux-f-card-sm">
        <div class="ux-f-card-visual">
          <div id="shield-animation-container">
            <svg class="shield-icon" width="24" height="24" viewBox="0 0 24 24">
              <path fill="#D94A4A" d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12c5.16-1.26 9-6.45 9-12V5l-9-4z"/>
            </svg>
            <div class="wave-container">
              <div class="wave wave-1"></div>
              <div class="wave wave-2"></div>
              <div class="wave wave-3"></div>
            </div>
          </div>
        </div>
        <div class="ux-f-card-info">
          <div class="ux-f-card-info-title">Safe &amp; Undetected.</div>
          <div class="ux-f-card-info-desc">We provide the most secure and undetected products on the market.</div>
        </div>
      </div>
      <div class="ux-f-card ux-f-card-md">
        <div class="ux-f-card-visual">
          <div class="ux-f-delivery">
            <div class="ux-f-delivery-order">
              <span class="ux-f-delivery-order-id">Order #8492</span>
              <span class="ux-f-delivery-status">Delivered</span>
            </div>
            <div class="ux-f-delivery-bar">
              <div class="ux-f-delivery-bar-track">
                <div class="ux-f-delivery-bar-fill"></div>
              </div>
            </div>
            <div class="ux-f-delivery-details">
              <div class="ux-f-delivery-details-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"><path fill="currentColor" d="M21 16.5C21 16.88 20.79 17.21 20.47 17.38L12.57 21.82C12.41 21.94 12.21 22 12 22C11.79 22 11.59 21.94 11.43 21.82L3.53 17.38C3.21 17.21 3 16.88 3 16.5V7.5C3 7.12 3.21 6.79 3.53 6.62L11.43 2.18C11.59 2.06 11.79 2 12 2C12.21 2 12.41 2.06 12.57 2.18L20.47 6.62C20.79 6.79 21 7.12 21 7.5V16.5M12 4.15L5 8.09V15.91L12 19.85L19 15.91V8.09L12 4.15M12 6.23L16.9 9.16L12 12.09L7.1 9.16L12 6.23M17 14.89L13 17.2V12.46L17 10.15V14.89Z"/></svg>
              </div>
              <div class="ux-f-delivery-details-text">
                <span class="ux-f-delivery-details-title">Login Details</span>
                <span class="ux-f-delivery-details-sub">Sent to email</span>
              </div>
            </div>
          </div>
        </div>
        <div class="ux-f-card-info">
          <div class="ux-f-card-info-title">Instant Delivery.</div>
          <div class="ux-f-card-info-desc">Experience instant key delivery.</div>
        </div>
      </div>
      <div class="ux-f-card ux-f-card-md">
        <div class="ux-f-card-visual">
          <div class="ux-f-support-text">
            <span>24/7</span>
            <span>Support</span>
          </div>
        </div>
        <div class="ux-f-card-info">
          <div class="ux-f-card-info-title">24/7 Support</div>
          <div class="ux-f-card-info-desc">We provide fast, responsive support you'll never be left waiting, and our team is always ready to help anytime.</div>
        </div>
      </div>
      <div class="ux-f-card ux-f-card-lg">
        <div class="ux-f-card-visual">
          <div class="ux-f-menu-outer">
          <div class="ux-f-menu" x-data="{ activeTab: 'aim' }">
