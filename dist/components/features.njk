<link rel="stylesheet" href="{{ 'features_utilities.css' | assetUrl }}" />

<section id="ux-features" class="component" data-component-id="{{ componentId }}">
  <div class="glow-center"></div>
  <div class="glow-top-right"></div>
  <div class="glow-bottom-left"></div>
  <div class="ux-f-inner" data-aos="fade-up">
