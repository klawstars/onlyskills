{% set hasLinks = global.components.footer.links.length > 0 %}
{% set hasLinks2 = global.components.footer.links_2.length > 0 %}
{% set hasSocials = global.components.footer.show_socials %}

{% if global.components.footer.show_shop_name or global.components.footer.show_logo or global.components.footer.show_socials or global.components.footer.links.length > 0 %}
  <footer class="footer component ux-footer" id="contact" data-component-id="footer">
    <div class="ux-footer-glow-left"></div>
    <div class="ux-footer-glow-right"></div>
    <div class="container" style="position: relative; z-index: 1;">
      <div class="ux-footer-grid">
        <div class="ux-footer-brand" style="align-items: flex-start; gap: 0.75rem;">
          <a href="{{ '/' | shopUrl }}" style="display: inline-block; margin-left: 0.25rem; margin-top: 0.5rem;">
            <img src="https://i.imgur.com/CvOUkWj.png" alt="{{ shop.name }}" style="height: 48px; width: auto; display: block;">
          </a>
          <p style="color: rgba(255, 255, 255, 0.45); font-size: 0.82rem; line-height: 1.55; margin: 0; margin-left: 1rem; max-width: 260px;">OnlySkills provides the best products on the market at a low price and with fast support.</p>
          <div style="display: inline-flex; align-items: center; gap: 0.45rem; background: rgba(255, 255, 255, 0.06); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 999px; padding: 0.45rem 0.95rem; margin-left: 1rem;">
            <span style="width: 8px; height: 8px; min-width: 8px; background: #D94A4A; border-radius: 50%; display: inline-block;"></span>
            <span style="font-size: 0.78rem; font-weight: 600; white-space: nowrap; line-height: 1;"><span style="color: #D94A4A;" id="visitor-count"></span> <span style="color: rgba(255, 255, 255, 0.9);">Visitors Online</span></span>
            <script>document.getElementById('visitor-count').textContent=Math.floor(Math.random()*75)+60;</script>
          </div>
        </div>

        <div class="ux-footer-links-group">
          {% if hasLinks %}
          <div class="ux-footer-col">
            <h3>{% if global.components.footer.links_title %}{{ global.components.footer.links_title }}{% else %}Navigation{% endif %}</h3>
            <ul>
              {% for link in global.components.footer.links %}
              {% set footerHref = link.link | shopUrl %}
              {% if footerHref != '/feedback' and footerHref != '/vouches' %}
                <li><a href="{{ footerHref }}" target="{{ 'blank' if link.new_tab }}">{{ link.text }}</a></li>
              {% endif %}
              {% endfor %}
            </ul>
          </div>
          {% endif %}

          {% if hasLinks2 %}
          <div class="ux-footer-col">
            <h3>{{ global.components.footer.links_2_title }}</h3>
            <ul>
              {% for link in global.components.footer.links_2 %}
              <li><a href="{{ link.link | shopUrl }}" target="{{ 'blank' if link.new_tab }}">{{ link.text }}</a></li>
              {% endfor %}
            </ul>
          </div>
          {% endif %}

          {% if hasSocials %}
          <div class="ux-footer-col">
            <h3>Socials</h3>
            <ul>
              <li><a href="https://discord.gg/onlyskillsback" target="_blank">Discord</a></li>
              {% if shop.telegram_url %}
              <li><a href="{{ shop.telegram_url }}" target="_blank">Telegram</a></li>
              {% endif %}
              {% if shop.instagram_url %}
              <li><a href="{{ shop.instagram_url }}" target="_blank">Instagram</a></li>
              {% endif %}
              {% if shop.tiktok_url %}
              <li><a href="{{ shop.tiktok_url }}" target="_blank">TikTok</a></li>
              {% endif %}
              {% if shop.youtube_url %}
              <li><a href="{{ shop.youtube_url }}" target="_blank">YouTube</a></li>
              {% endif %}
            </ul>
          </div>
          {% endif %}
        </div>
      </div>

      <div class="ux-footer-bottom">
        <p>Copyright &copy; 2025. All Rights Reserved.</p>
      </div>
    </div>
  </footer>
{% endif %}
