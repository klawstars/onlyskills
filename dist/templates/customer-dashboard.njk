<div class="cust-page component" data-component-id="{{ componentId }}">
  {% render_snippet "customer-greeting.njk" %}

  <div class="container" style="max-width: 1200px;">
    <div class="row">
      <div class="col-12 col-lg-3 mb-4">
        {% render_snippet "customer-sidebar.njk" %}
      </div>
      <div class="col-12 col-lg-9">
        <div class="row">
          <div class="col-12 col-md-6 col-lg-4 mb-4">
            <div class="cust-stat-card">
              <span class="cust-stat-label">Completed Orders</span>
              <span class="cust-stat-value">{{ shop_customer.total_completed }}</span>
            </div>
          </div>
          <div class="col-12 col-md-6 col-lg-4 mb-4">
            <div class="cust-stat-card">
              <span class="cust-stat-label">Total Spent</span>
              <span class="cust-stat-value">
                <span x-text="appCurrency.format({{ shop_customer.total_spent_usd }}, 'USD')">
                  {{ formatPrice(shop_customer.total_spent_usd, 'USD') }}
                </span>
              </span>
            </div>
          </div>
          <div class="col-12 col-md-6 col-lg-4 mb-4">
            <div class="cust-stat-card">
              <span class="cust-stat-label">Customer Since</span>
              <span class="cust-stat-value">{{ shop_customer.created_at | formatDate }}</span>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-12 col-lg-8 mb-4">
            <div class="cust-stat-card">
              <span class="cust-stat-label">Latest Order</span>
              {% if latest_invoice %}
                <span class="cust-stat-value" style="font-size: 1.1rem;">
                  {% if latest_invoice.items %}
                    {{ latest_invoice.items[0].product.name }}
                    {% if latest_invoice.items[0].variant and latest_invoice.items[0].product.name != latest_invoice.items[0].variant.name %}
                      ({{ latest_invoice.items[0].variant.name }})
                    {% endif %}
                    {% if latest_invoice.items.length > 1 %}
                      & {{ latest_invoice.items.length - 1 }} more
                    {% endif %}
                  {% else %}
                    Deleted Product
                  {% endif %}
                </span>
                <small class="text-muted mt-1">
                  <a href="{{ latest_invoice.url }}" target="_blank" class="text-muted text-decoration-none">
                    Invoice <span class="text-primary">#{{ latest_invoice.unique_id }}</span>
                  </a>
                  - {{ latest_invoice.created_at | formatDate }}
                </small>
              {% else %}
                <span class="cust-stat-value">None</span>
              {% endif %}
            </div>
          </div>
          {% if shop.customer_balance_enabled %}
            <div class="col-12 col-lg-4 mb-4">
              <div class="cust-stat-card">
                <span class="cust-stat-label">Balance</span>
                <span class="cust-stat-value">
                  <span x-text="appCurrency.format({{ shop_customer.balance }}, 'USD')">
                    {{ formatPrice(shop_customer.balance, 'USD') }}
                  </span>
                </span>
                <a href="{{ '/customer/balance' | shopUrl }}" class="cust-topup-link">Top Up</a>
              </div>
            </div>
          {% endif %}
        </div>
        <div class="row">
          <div class="col-12 d-flex justify-content-end">
            <button type="button" data-bs-toggle="modal" data-bs-target="#customer-delete-modal" class="cust-delete-btn">
              Delete Account <i class="fa-solid fa-trash-can"></i>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div
  x-cloak
  class="fixed inset-0 z-50 overflow-y-auto"
  aria-labelledby="delete-modal-title"
  role="dialog"
  aria-modal="true"
>
  <div class="modal fade" id="customer-delete-modal" tabindex="-1" aria-labelledby="customer-delete-modal-label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="customer-delete-modal-label">
            Delete Customer Account
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="mb-4">
            This action cannot be undone and will permanently remove all your data, order history and balance.
          </p>
          <div class="row">
            <div class="col-12 col-md-6">
              <button
                type="button"
                data-bs-dismiss="modal"
                class="w-100 btn btn-outline-primary"
              >
                <span>Cancel</span>
                <i class="fa fa-times"></i>
              </button>
            </div>
            <div class="col-12 col-md-6">
              <button
                type="button"
                @click="appCustomer.deleteAccount()"
                class="w-100 btn btn-danger"
                :disabled="appCustomer.deleteModalLoading"
              >
                <span>Delete Account</span>
                <template x-if="!appCustomer.deleteModalLoading">
                  <i class="fa fa-trash"></i>
                </template>
                <template x-if="appCustomer.deleteModalLoading">
                  <i class="fa fa-circle-notch animate-spin"></i>
                </template>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="components">
  {% for componentId in components_order %}
    {% render_component componentId %}
  {% endfor %}
</div>