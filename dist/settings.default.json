        "components": {
            "announcement": {
                "text": "Trusted by thousands of satisfied customers",
                "link": "/#products",
                "link_text": "View Products"
            },
            "navbar": {
                "show_shop_name": true,
                "show_logo": true,
                "left_links": [
                    {
                        "text": "Products",
                        "link": "/products",
                        "shape": "regular"
                    },
                    {
                        "text": "Status",
                        "link": "/status",
                        "shape": "regular"
                    },
                    {
