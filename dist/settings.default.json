{
    "templates": {
        "shop": {
            "layout": "master",
            "components": {
                "hero": {
                    "type": "hero",
                    "properties": {
                        "title": "The Marketplace built to be better.",
                        "subtitle": null,
                        "cta": "/#products",
                        "cta_text": "Explore Products",
                        "show_searchbar": false,
                        "show_feedback_rating": false,
                        "show_products_sold": false,
                        "show_total_customers": true,
                        "alignment": "center",
                        "height": "tall",
                        "background_image": null,
                        "side_image": null
                    }
                },
                "products": {
                    "type": "products",
                    "properties": {
                        "title": "Our Products",
                        "subtitle": "Browse our selection of premium products"
                    }
                },
                "feedbacks": {
                    "type": "feedbacks",
                    "properties": {
                        "title": "Customer Reviews",
                        "subtitle": "See what our customers have to say",
                        "amount": 4
                    }
                },
                "socials": {
                    "type": "socials",
                    "properties": {
                        "title": "Join Our Community",
                        "subtitle": null
                    }
                }
            },
            "components_order": [
                "hero",
                "products",
                "feedbacks",
                "socials"
            ]
        },
        "cart": {
            "layout": "master",
            "components": {
                "cart-page": {
                    "type": "cart-page",
                    "properties": []
                }
            },
            "components_order": [
                "cart-page"
            ]
        },
        "products": {
            "layout": "master",
            "components": {
                "products-page": {
                    "type": "products-page",
                    "properties": {
                        "default_title": "Our Products",
                        "category_title": "{{ category.name }} Products"
                    }
                }
            },
            "components_order": [
                "products-page"
            ]
        },
        "product": {
            "layout": "master",
            "components": {
                "product-page": {
                    "type": "product-page",
                    "properties": {
                        "hide_add_to_cart": false,
                        "hide_buy_now": false
