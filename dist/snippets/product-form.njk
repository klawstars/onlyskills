<form @submit.prevent="buyNow" class="sa-buy-form">
  <div class="sa-form-head">
    <span>Select Option</span>
    <div class="sa-qty-inline">
      <button
        @click="changeQuantity(quantity - 1)"
        type="button"
        :disabled="outOfStock || quantity <= minQuantity"
        aria-label="Decrease quantity"
      >
        <i class="fa-solid fa-minus"></i>
      </button>
      <span x-text="quantity"></span>
      <button
        @click="changeQuantity(quantity + 1)"
        type="button"
        :disabled="outOfStock || quantity >= maxQuantity"
        aria-label="Increase quantity"
      >
        <i class="fa-solid fa-plus"></i>
      </button>
    </div>
  </div>

  {% if product.variants and product.variants.length > 0 %}
    <div class="sa-variant-grid">
      {% for variant in product.variants %}
        <button
          type="button"
          class="sa-variant-card"
          :class="{ 'active': activeVariant == {{ loop.index0 }} }"
          @click="() => { if (!isVariantDisabled({{ loop.index0 }})) { activeVariant = {{ loop.index0 }}; quantity = 1; } }"
          :disabled="isVariantDisabled({{ loop.index0 }})"
          :title="isVariantDisabled({{ loop.index0 }}) ? 'Out of Stock' : ''"
        >
          <div class="sa-variant-title-row">
            <span class="sa-variant-name">{{ variant.name }}</span>
            <div class="sa-variant-right">
              <template x-if="isVariantDisabled({{ loop.index0 }})">
                <span class="sa-out-tag">OUT OF STOCK</span>
              </template>
              <template x-if="activeVariant == {{ loop.index0 }} && !isVariantDisabled({{ loop.index0 }})">
                <i class="fa-solid fa-check sa-check"></i>
              </template>
            </div>
          </div>

          {% if variant.description %}
            <p class="sa-variant-desc">{{ variant.description }}</p>
          {% endif %}

          <div class="sa-variant-price">
            <span x-text="appCurrency.format({{ variant.price }}, '{{ product.currency }}')">
              {{ formatPrice(variant.price, product.currency) }}
            </span>
            {% if variant.price_slash %}
              <s>
                <span x-text="appCurrency.format({{ variant.price_slash }}, '{{ product.currency }}')">
                  {{ formatPrice(variant.price_slash, product.currency) }}
                </span>
              </s>
            {% endif %}
          </div>

          <div class="sa-variant-stock">
            <template x-if="isVariantDisabled({{ loop.index0 }})">
              <span>Out of stock</span>
            </template>
            <template x-if="!isVariantDisabled({{ loop.index0 }}) && {{ 'true' if product.hide_stock_count else 'false' }}">
              <span>In stock</span>
            </template>
            <template x-if="!isVariantDisabled({{ loop.index0 }}) && !{{ 'true' if product.hide_stock_count else 'false' }} && stockValue({{ loop.index0 }}) === -1">
              <span>In stock</span>
            </template>
            <template x-if="!isVariantDisabled({{ loop.index0 }}) && !{{ 'true' if product.hide_stock_count else 'false' }} && stockValue({{ loop.index0 }}) !== -1">
              <span x-text="`${stockValue({{ loop.index0 }})} in stock`"></span>
            </template>
          </div>
        </button>
      {% endfor %}
    </div>
  {% endif %}

  <small
    x-show="showQuantityWarning && !outOfStock"
    x-cloak
    class="form-text text-danger mt-2"
  >
    Please enter a valid quantity (from <span x-text="minQuantity"></span> to <span x-text="maxQuantity"></span>).
  </small>

  <div x-show="nextVolumeDiscount" class="sa-volume-tip">
    Buy <span x-text="nextVolumeDiscount?.quantity - quantity"></span> more to get a
    <span x-text="nextVolumeDiscount?.percentage"></span>% discount.
  </div>

  {% if productAddons and productAddons.length > 0 %}
    <div class="sa-addons">
      <div class="sa-addons-label">Addons</div>
      <div class="d-flex flex-column gap-2">
        {% for addon in productAddons %}
          <div class="addon-item d-flex align-items-center justify-content-between gap-3 p-3 rounded">
            <div class="d-flex align-items-center gap-2 flex-grow-1">
              {% if addon.image_urls and addon.image_urls[0] %}
                <img 
                  src="{{ addon.image_urls[0] }}" 
                  alt="{{ addon.name }}"
                  class="addon-image rounded"
                >
              {% endif %}
              <div class="flex-grow-1">
                <p class="mb-1 fw-medium">{{ addon.name }}</p>
                {% if addon.description %}
                  <p class="mb-1 small text-muted" style="white-space: pre-line;">{{ addon.description }}</p>
                {% endif %}
              </div>
            </div>
            <div class="d-flex align-items-center gap-3">
              <span class="fw-medium" x-text="appCurrency.format('{{ addon.variants[0].price }}', '{{ addon.currency }}')">
                {{ formatPrice(addon.variants[0].price, addon.currency) }}
              </span>
              <button
                type="button"
                x-show="!appCart.isInCart({{ addon.variants[0].id }}, variant.id)"
                x-on:click="appCart.add({{ addon.id }}, {{ addon.variants[0].id }}, 1, variant.id)"
                class="btn btn-sm btn-addon-add d-flex justify-content-center align-items-center gap-1"
                :disabled="outOfStock || product.visibility == 'on_hold' || cartLimitReached || addingToCart"
              >
                <span>Add</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24"><path fill="currentColor" d="M11 13H6q-.425 0-.712-.288T5 12t.288-.712T6 11h5V6q0-.425.288-.712T12 5t.713.288T13 6v5h5q.425 0 .713.288T19 12t-.288.713T18 13h-5v5q0 .425-.288.713T12 19t-.712-.288T11 18z"/></svg>
              </button>
              {% if addon.is_mandatory %}
                <button
                  type="button"
                  x-show="appCart.isInCart({{ addon.variants[0].id }}, variant.id)"
                  class="btn btn-sm btn-addon-add d-flex justify-content-center align-items-center gap-1"
                  disabled
                  title="This addon is mandatory"
                >
                  <span>Added</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24"><path fill="currentColor" d="m9.55 15.15l8.475-8.475q.3-.3.7-.3t.7.3t.3.713t-.3.712l-9.175 9.2q-.3.3-.7.3t-.7-.3L4.55 13q-.3-.3-.288-.712t.313-.713t.713-.3t.712.3z"/></svg>
                </button>
              {% else %}
                <button
                  type="button"
                  x-show="appCart.isInCart({{ addon.variants[0].id }}, variant.id)"
                  x-on:click="appCart.remove({{ addon.variants[0].id }}, variant.id)"
                  class="btn btn-sm btn-addon-remove d-flex justify-content-center align-items-center gap-1"
                  :disabled="outOfStock || product.visibility == 'on_hold' || cartLimitReached || addingToCart"
                >
                  <span>Remove</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24"><path fill="currentColor" d="m12 13.4l-4.9 4.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7l4.9-4.9l-4.9-4.9q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.9 4.9l4.9-4.9q.275-.275.7-.275t.7.275t.275.7t-.275.7L13.4 12l4.9 4.9q.275.275.275.7t-.275.7t-.7.275t-.7-.275z"/></svg>
                </button>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if altcha and not properties.hide_buy_now %}
    <div
      x-cloak
      x-show="!altchaPayload"
      class="transition-opacity mt-2"
      x-transition:enter="transition ease-out duration-300 transform"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-200 transform"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
    >
      <altcha-widget
        challengejson='{{ altcha | json }}'
        auto="onload"
        hidefooter="true"
        hidelogo="true"
        x-ref="altcha"
      ></altcha-widget>
    </div>
  {% endif %}

  <div
    x-cloak
    x-show="buyNowError"
    class="transition-opacity mt-2"
    x-transition:enter="transition ease-out duration-300 transform"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-200 transform"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
  >
    <div class="alert alert-warning mb-0" role="alert" x-text="buyNowError"></div>
  </div>

  <div class="sa-cta-row">
    {% if not properties.hide_buy_now %}
      <button
        type="submit"
        class="sa-buy-btn"
        :disabled="outOfStock || product.visibility == 'on_hold' || buyingNow || buyNowDisabled"
      >
        <template x-if="!buyingNow">
          <span class="sa-btn-content">
            <i class="fa-regular fa-credit-card"></i>
            <span>Buy Now</span>
          </span>
        </template>
        <template x-if="buyingNow">
          <span class="sa-btn-content">
            <i class="fa-solid fa-spinner fa-spin"></i>
            <span>Processing...</span>
          </span>
        </template>
      </button>
    {% endif %}

    {% if not properties.hide_add_to_cart %}
      <button
        type="button"
        x-on:click="addToCart"
        class="sa-cart-btn"
        :disabled="outOfStock || product.visibility == 'on_hold' || cartLimitReached || addingToCart"
      >
        <template x-if="!addingToCart && !addedToCart">
          <span class="sa-btn-content">
            <i class="fa-solid fa-cart-shopping"></i>
            <span x-text="cartLimitReached ? 'Cart Limit Reached' : 'Add to Cart'"></span>
          </span>
        </template>
        <template x-if="addingToCart">
          <span class="sa-btn-content">
            <i class="fa-solid fa-spinner fa-spin"></i>
            <span>Adding...</span>
          </span>
        </template>
        <template x-if="addedToCart">
          <span class="sa-btn-content">
            <i class="fa-solid fa-arrow-right"></i>
            <span>Go to Cart</span>
          </span>
        </template>
      </button>
    {% endif %}
  </div>

  <div class="sa-trust-row">
    <span><i class="fa-solid fa-lock"></i> Secure Payment</span>
    <span><i class="fa-solid fa-bolt"></i> Instant Delivery</span>
    <span><i class="fa-solid fa-headset"></i> 24/7 Support</span>
  </div>
</form>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('productForm', () => ({
      product: {{ product | json }},
      productAddons: {{ productAddons | json }},
      activeVariant: 0,
      quantity: {{ product.quantity_min or 1 }},
      isEmbed: {{ 'true' if is_embed else 'false' }},
      addingToCart: false,
      addedToCart: false,
      buyingNow: false,
      buyNowError: null,
      showQuantityWarning: false,
      buyNowDisabled: false,
      altchaPayload: null,

      get variant() {
        return this.product.variants[this.activeVariant];
      },

      stockValue(index = this.activeVariant) {
        const raw = this.product?.variants?.[index]?.stock;
        const parsed = Number(raw);
        return Number.isFinite(parsed) ? parsed : -1;
      },

      minValue(index = this.activeVariant) {
        const raw = this.product?.variants?.[index]?.quantity_min;
        const parsed = Number(raw);
        return Number.isFinite(parsed) && parsed > 0 ? parsed : 1;
      },

      maxValue(index = this.activeVariant) {
        const raw = this.product?.variants?.[index]?.quantity_max;
        const parsed = Number(raw);
        return Number.isFinite(parsed) && parsed > 0 ? parsed : 999999;
      },

      isVariantDisabled(index = this.activeVariant) {
        const stock = this.stockValue(index);
        const min = this.minValue(index);

        if (stock === 0) {
          return true;
        }

        if (this.product.hide_stock_count || stock === -1) {
          return false;
        }

        return stock < min;
      },

      normalizeQuantity() {
        const numeric = Number(this.quantity);

        if (!Number.isFinite(numeric)) {
          this.quantity = this.minQuantity;
          this.showQuantityWarning = false;
          return;
        }

        if (numeric < this.minQuantity) {
          this.quantity = this.minQuantity;
          this.showQuantityWarning = false;
          return;
        }

        if (numeric > this.maxQuantity) {
          this.quantity = this.maxQuantity;
          this.showQuantityWarning = false;
          return;
        }

        this.quantity = numeric;
        this.showQuantityWarning = false;
      },

      init: function () {
        const urlParams = new URLSearchParams(window.location.search);

        // Prefill variant from URL parameter if present.
        if (urlParams.has('variant')) {
          const variantIndex = this.product.variants.findIndex(variant => variant.name === urlParams.get('variant'));
          if (variantIndex !== -1 && !this.isVariantDisabled(variantIndex)) {
            this.activeVariant = variantIndex;
          }
        } else {
          // Choose the first variant that has stock.
          for (let i = 0; i < this.product.variants.length; i++) {
            if (!this.isVariantDisabled(i)) {
              this.activeVariant = i;
              break;
            }
          }
        }

        this.quantity = this.minValue();
        this.normalizeQuantity();

        if (urlParams.has('quantity')) {
          const urlQuantity = parseInt(urlParams.get('quantity'));
          if (!isNaN(urlQuantity) && urlQuantity >= this.minQuantity && urlQuantity <= this.maxQuantity) {
            this.quantity = urlQuantity;
          }
        }

        this.$watch('activeVariant', () => {
          this.quantity = this.minValue();
          this.normalizeQuantity();

          this.addedToCart = false;

          // Add mandatory addons.
          for (const addon of this.productAddons) {
            if (addon.is_mandatory) {
              if (!this.appCart.isInCart(addon.variants[0].id, this.variant.id)) {
                this.appCart.add(addon.id, addon.variants[0].id, 1, this.variant.id);
              }
            }
          }
        });

        this.$watch('quantity', () => {
          this.normalizeQuantity();
          this.showQuantityWarning = false;
          this.addedToCart = false;
        });

        {% if altcha and not properties.hide_buy_now %}
          this.addAltchaEventListener();
        {% endif %}
      },

      get nextVolumeDiscount() {
        if (this.variant.volume_discounts) {
          const volumeDiscounts = [...this.variant.volume_discounts].sort((a, b) => a.quantity - b.quantity);

          for (const volumeDiscount of volumeDiscounts) {
            if (this.quantity < parseInt(volumeDiscount.quantity)) {
              return volumeDiscount;
            }
          }
        }

        return null;
      },

      getAppliedVolumeDiscount: function (quantity = null) {
        if (quantity === null) {
          quantity = this.quantity;
        }

        if (this.variant.volume_discounts) {
          const volumeDiscounts = [...this.variant.volume_discounts].sort((a, b) => b.quantity - a.quantity);

          for (const volumeDiscount of volumeDiscounts) {
            if (quantity >= parseInt(volumeDiscount.quantity)) {
              return volumeDiscount;
            }
          }
        }

        return null;
      },

      get unitPrice() {
        const quantity = 1;

        let price = this.variant.price * quantity;

        // Apply volume discounts
        const appliedVolumeDiscount = this.getAppliedVolumeDiscount(quantity);
        if (appliedVolumeDiscount) {
          price = price - (this.variant.price * parseInt(appliedVolumeDiscount.percentage) / 100);
        }

        // Format the price to have 2 decimal places
        const formattedPrice = price.toFixed(2);

        return formattedPrice;
      },

      get totalPrice() {
        let price = this.variant.price * this.quantity;
        let priceBeforeDiscounts = price;

        // Apply volume discounts
        const appliedVolumeDiscount = this.getAppliedVolumeDiscount();
        if (appliedVolumeDiscount) {
          price -= (priceBeforeDiscounts * parseInt(appliedVolumeDiscount.percentage) / 100);
        }

        // Append prices of addons
        if (this.appCart.items.length > 0) {
          for (const item of this.appCart.items) {
            if (item.parentVariantId === this.variant.id) {
              const addonVariant = this.productAddons.find(addon => addon.id === item.productId && addon.variants.some(variant => variant.id === item.variantId));
              if (addonVariant) {
                const addonPrice = addonVariant.variants.find(variant => variant.id === item.variantId).price;
                price += addonPrice * item.quantity;
              }
            }
          }
        }

        // If price is negative, set it to 0
        if (price < 0) {
          price = 0;
        }

        // Format the price to have 2 decimal places
        const formattedPrice = price.toFixed(2);

        return formattedPrice;
      },

      get outOfStock() {
        return this.isVariantDisabled();
      },

      get minQuantity() {
        const min = this.minValue();
        if (this.stockValue() === 0) {
          return 0;
        }
        return min;
      },

      get maxQuantity() {
        const max = this.maxValue();
        const stock = this.stockValue();
        const min = this.minValue();

        if (stock === 0) {
          return 0;
        }

        if (this.product.hide_stock_count) {
          return max;
        }

        if (stock === -1) {
          return Math.max(min, max);
        }

        return Math.max(min, Math.min(max, stock));
      },

      changeQuantity: function (quantity) {
        const min = this.minQuantity;
        const max = this.maxQuantity;
        const newQuantity = Math.min(Math.max(min, quantity), max);

        this.quantity = newQuantity;
        this.showQuantityWarning = false;
      },

      get cartLimitReached() {
        const nonAddonItemsCount = this.appCart.items
          .filter(item => !item.parentVariantId)
          .length;

        return nonAddonItemsCount >= {{ shop.max_cart_limit }};
      },

      addToCart: function () {
        if (this.addedToCart) {
          window.location.href = '{{ '/cart' | shopUrl }}';
          return;
        }

        this.addingToCart = true;

        const productId = this.product.id;
        const variantId = this.variant.id;
        const quantity = this.quantity;

        this.appCart.add(productId, variantId, quantity);

        setTimeout(() => {
          this.addedToCart = true;
          this.addingToCart = false;
        }, 1000);
      },

      addAltchaEventListener: function () {
        this.$refs.altcha.addEventListener('statechange', (event) => {
          if (event.detail.state === 'verifying') {
            this.buyNowDisabled = true;
          } else if (event.detail.state === 'verified') {
            this.buyNowDisabled = false;
            this.altchaPayload = event.detail.payload;
          }
        });
      },

      generateRecaptchaToken: async function () {
        return new Promise((resolve) => {
          grecaptcha.ready(
            () =>
              void (async () => {
                const token = await grecaptcha.execute(
                  '{{ shop.recaptcha_key }}',
                  { action: 'buynow_s{{ shop.id }}' },
                );

                resolve(token);
              })(),
          );
        });
      },

      buyNow: async function () {
        if (this.buyingNow) {
          return;
        }

        this.buyNowError = null;
        this.showQuantityWarning = false;
        this.normalizeQuantity();

        if (this.quantity < this.minQuantity || this.quantity > this.maxQuantity) {
          this.showQuantityWarning = true;
          this.buyNowError = `Please enter a valid quantity (from ${this.minQuantity} to ${this.maxQuantity}).`;
          return;
        }

        const buyNowCart = [{
          productId: this.product.id,
          variantId: this.variant.id,
          quantity: this.quantity,
        }];

        if (this.appCart.items.length > 0) {
          for (const item of this.appCart.items) {
            if (item.parentVariantId === this.variant.id) {
              buyNowCart.push({
                productId: item.productId,
                variantId: item.variantId,
                parentVariantId: item.parentVariantId,
                quantity: item.quantity,
              });
            }
          }
        }

        const formData = {
          cart: buyNowCart,
          currency: this.appCurrency.currency,
          shopId: '{{ shop.id }}',
        };

        if (window.shopCustomer?.email) {
          formData.email = window.shopCustomer.email;
        }

        {% if altcha %}
          if (this.altchaPayload) {
            formData.altcha = this.altchaPayload;
          }
        {% elif shop.recaptcha_key %}
          try {
            formData.recaptchaToken = await this.generateRecaptchaToken();
          } catch (error) {
            this.buyNowError = 'reCAPTCHA cannot be loaded. Please refresh the page and turn off any ad blockers.';
            this.buyingNow = false;
            return;
          }
        {% endif %}

        try {
          this.buyingNow = true;

          const response = await fetch('{{ '/v1/checkout' | apiInternalUrl }}', {
            method: 'POST',
            headers: {
              'Accept': 'application/json',
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData),
          });

          const responseData = await response.json();

          if (responseData.url) {
            this.checkoutUrl = responseData.url;

            // Open in new tab if we're in an embed.
            if (this.isEmbed) {
              window.open(this.checkoutUrl, '_blank');
            } else {
              window.location.href = this.checkoutUrl;
            }
          } else {
            this.buyingNow = false;
            this.buyNowError = responseData?.message || 'Error in the AJAX request.';

            if (responseData?.error == 'captcha_verification_failed') {
              setTimeout(() => window.location.reload(), 1000);
            }
          }
        } catch (error) {
          console.error(error);
          this.buyingNow = false;
          this.buyNowError = 'Unexpected error. Please refresh the page and try again.';
        }
      }
    }));
  });
</script>

<script>
  window.addEventListener('load', () => {
    if (document.querySelector('select[name="variant"]')) {
     new Choices('select[name="variant"]', { searchPlaceholderValue: 'Search for a variant...', shouldSort: false });
    }
  });
</script>
