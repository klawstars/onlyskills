<a
  class="card ux-product-card text-decoration-none {{ 'ux-group-card' if product.type == 'group' else '' }}"
  href="{{ (( '/products/' + product.path) if product.type == 'group' else ('/product/' + product.path)) | shopUrl }}"
  data-aos="fade-up"
>
  <div class="ux-card-image">
    {% if product.image_urls|length > 0 %}
    <img src="{{ product.image_urls[0] }}" class="img-fluid" loading="lazy" />
    {% elif product.image_url %}
    <img src="{{ product.image_url }}" class="img-fluid" loading="lazy" />
    {% else %}
    <div class="ux-card-placeholder">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 256 256"><path fill="currentColor" d="m222.72 67.91l-88-48.18a13.9 13.9 0 0 0-13.44 0l-88 48.18A14 14 0 0 0 26 80.18v95.64a14 14 0 0 0 7.28 12.27l88 48.18a13.92 13.92 0 0 0 13.44 0l88-48.18a14 14 0 0 0 7.28-12.27V80.18a14 14 0 0 0-7.28-12.27Z"/></svg>
    </div>
    {% endif %}
    <div class="ux-card-img-overlay"></div>
  </div>
  <div class="ux-card-body">
    <div class="ux-card-header">
      <h5 class="ux-card-title">{{ product.name }}</h5>
      {% if product.product_badges.card|length > 0 %}
      <div class="ux-card-badges">
        {% for productBadge in product.product_badges.card %}
        <div class="ux-game-badge" style="--badge-color: {{ productBadge.color }};">
          <span class="ux-badge-dot"></span>
          {% if productBadge.icon %}
            <i class="{{ productBadge.icon }} fa-fw"></i>
          {% endif %}
          <span>{{ productBadge.label }}</span>
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
    <div class="ux-card-divider"></div>
    <div class="ux-card-footer">
      <div class="ux-card-meta">
        {% if product.type == 'group' %}
        <span class="ux-meta-count">{{ product.products|length }} Products</span>
        {% endif %}
      </div>
      <div class="ux-price-value">
        {% if product.min_price != product.max_price %}
          <span x-text="appCurrency.format({{ product.min_price }}, '{{ product.currency }}')">
            {{ formatPrice(product.min_price, product.currency) }}
          </span>+
        {% elif product.min_price %}
          <span x-text="appCurrency.format({{ product.min_price }}, '{{ product.currency }}')">
            {{ formatPrice(product.min_price, product.currency) }}
          </span>{% if product.type == 'group' %}+{% endif %}
        {% else %}
          -
        {% endif %}

        {% if product.min_price_slash %}
          <s class="ux-price-slash">
            <span x-text="appCurrency.format({{ product.min_price_slash }}, '{{ product.currency }}')">
              {{ formatPrice(product.min_price_slash, product.currency) }}
            </span>
          </s>
        {% endif %}
      </div>
    </div>
  </div>
</a>
