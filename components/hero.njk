{% set videoUrl = properties.video_url or '/assets/video.mp4' %}
{% if properties.background_image and properties.background_image != 'DEFAULT' %}
  {% set bgImageUrl = properties.background_image | imageUrl %}
{% else %}
  {% set bgImageUrl = '' %}
{% endif %}

<section
  x-data="{
    searchTerm: '',
    shouldShowItem(el) {
      return this.searchTerm === '' || decodeHtmlEntities(el.dataset.name.toLowerCase()).includes(this.searchTerm.toLowerCase());
    }
  }"
  class="hero alignment-center height-{{ properties.height }} component ux-hero ux-hero-video-bg"
  style="{% if bgImageUrl %}background-image: url('{{ bgImageUrl }}');{% endif %}"
  data-component-id="{{ componentId }}"
>
  <div class="ux-hero-characters" aria-hidden="true">
    <video
      class="ux-hero-video"
      src="{{ videoUrl }}"
      autoplay
      muted
      loop
      playsinline
      webkit-playsinline
      preload="metadata"
    ></video>
  </div>

  <div class="ux-hero-video-overlay" aria-hidden="true"></div>
  <div class="ux-hero-glow" aria-hidden="true"></div>
  <div class="ux-hero-fade-bottom" aria-hidden="true"></div>

  <div class="container ux-hero-center">
    <div class="ux-hero-center-stack">

      <div class="ux-hero-split-badge" data-aos="fade-up">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" fill-rule="evenodd" d="m21.838 11.126l-.229 2.436c-.378 4.012-.567 6.019-1.75 7.228C18.678 22 16.906 22 13.36 22h-2.72c-3.545 0-5.317 0-6.5-1.21s-1.371-3.216-1.749-7.228l-.23-2.436c-.18-1.912-.27-2.869.058-3.264a1 1 0 0 1 .675-.367c.476-.042 1.073.638 2.268 1.998c.618.704.927 1.055 1.271 1.11a.92.92 0 0 0 .562-.09c.319-.16.53-.595.955-1.464l2.237-4.584C10.989 2.822 11.39 2 12 2s1.011.822 1.813 2.465l2.237 4.584c.424.87.636 1.304.955 1.464c.176.089.37.12.562.09c.344-.055.653-.406 1.271-1.11c1.195-1.36 1.792-2.04 2.268-1.998a1 1 0 0 1 .675.367c.327.395.237 1.352.057 3.264M12.952 12.7l-.098-.176c-.38-.682-.57-1.023-.854-1.023s-.474.341-.854 1.023l-.098.176c-.108.194-.162.29-.246.354c-.085.064-.19.088-.4.136l-.19.043c-.738.167-1.107.25-1.195.533c-.088.282.164.576.667 1.164l.13.152c.143.168.215.251.247.354c.032.104.021.215 0 .438l-.02.204c-.076.784-.114 1.177.115 1.351c.23.175.576.016 1.267-.303l.178-.082c.197-.09.295-.135.399-.135s.202.045.399.135l.178.082c.691.319 1.037.478 1.267.303c.23-.174.191-.567.115-1.352l-.02-.203c-.021-.223-.032-.334 0-.437c.032-.104.104-.187.247-.355l.13-.152c.503-.588.755-.882.667-1.165c-.088-.282-.457-.365-1.195-.532l-.19-.043c-.21-.048-.315-.072-.4-.136c-.084-.063-.138-.16-.246-.354" clip-rule="evenodd"/></svg>
        <span>Trusted by 5000+ Customers</span>
      </div>

      <h1 class="ux-hero-split-title ux-hero-center-title" data-aos="fade-up" data-aos-delay="100">
        <span class="ux-hero-split-brand">{{ properties.title | renderString }}</span>
        <span class="ux-hero-split-tagline">Products Made Better</span>
      </h1>

      {% if properties.subtitle %}
      <p class="ux-hero-split-subtitle ux-hero-center-subtitle" data-aos="fade-up" data-aos-delay="200">
        {{ properties.subtitle | renderString }}
      </p>
      {% endif %}

      <div class="ux-hero-split-actions ux-hero-center-actions" data-aos="fade-up" data-aos-delay="250">
        {% if properties.cta and properties.cta_text %}
        <a href="{{ properties.cta | shopUrl }}" class="ux-hero-btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
          <span>{{ properties.cta_text }}</span>
        </a>
        {% endif %}
        <a href="https://discord.gg/m3XXK2Wrgj" class="ux-hero-split-btn-secondary" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
          <span>Join Discord</span>
        </a>
      </div>

      <div class="ux-hero-split-stats ux-hero-center-stats" data-aos="fade-up" data-aos-delay="300">
        <div class="ux-hero-split-stat">
          <span class="ux-hero-split-stat-label">Happy Customers</span>
          <span class="ux-hero-split-stat-value">5,000+</span>
        </div>
        <div class="ux-hero-split-stat">
          <span class="ux-hero-split-stat-label">Instant Delivery</span>
          <span class="ux-hero-split-stat-value">24/7</span>
        </div>
        <div class="ux-hero-split-stat">
          <span class="ux-hero-split-stat-label">Customer Rating</span>
          <span class="ux-hero-split-stat-value">
            4.9
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>
          </span>
        </div>
      </div>

      {% if properties.show_searchbar %}
      <div class="form-group fake-searchbar ux-searchbar" data-bs-toggle="modal" data-bs-target="#searchModal" role="button" data-aos="fade-up" data-aos-delay="350">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256"><path d="M229.66,218.34l-50.07-50.06a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.32ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"></path></svg>
        <input type="text" class="form-control" placeholder="Search for products..." readonly>
      </div>
      {% endif %}

    </div>
  </div>

  <div class="ux-scroll-arrow" onclick="window.scrollTo({top: window.innerHeight, behavior: 'smooth'})">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#D94A4A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </div>

  {% if properties.show_searchbar %}
  <div class="modal fade search-modal" id="searchModal" x-data="searchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <div class="form-group searchbar">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M229.66,218.34l-50.07-50.06a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.32ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"></path></svg>
            <input type="text" class="form-control" placeholder="Search for products..." x-model="searchTerm">
          </div>
        </div>
        <div class="modal-body">
          <div class="products">
            {% for item in sortedItems %}
              {% if item.type != 'group' %}
                <div
                  x-show="shouldShowItem($el)"
                  x-transition
                  data-name="{{ item.name | lower | escape }}"
                >
                  {% render_snippet "product-card-horizontal.njk", product=item %}
                </div>
              {% else %}
                {% for product in item.products %}
                  <div
                    x-show="shouldShowItem($el)"
                    x-transition
                    data-name="{{ product.name | lower | escape }}"
                  >
                    {% render_snippet "product-card-horizontal.njk", product=product %}
                  </div>
                {% endfor %}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
    document.querySelector('.search-modal').addEventListener('shown.bs.modal', function() {
      this.querySelector('.searchbar input').focus();
    });
  </script>
  {% endif %}
</section>