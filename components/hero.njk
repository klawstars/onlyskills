{% if properties.background_image and properties.background_image != 'DEFAULT' %}
  {% set bgImageUrl = properties.background_image | imageUrl %}
{% else %}
  {% set bgImageUrl = '' %}
{% endif %}

<section
  x-data="{
    searchTerm: '',
    shouldShowItem(el) {
      return this.searchTerm === '' || decodeHtmlEntities(el.dataset.name.toLowerCase()).includes(this.searchTerm.toLowerCase());
    }
  }"
  class="hero alignment-{{ properties.alignment }} height-{{ properties.height }} component ux-hero"
  style="{% if bgImageUrl %}background-image: url('{{ bgImageUrl }}');{% endif %} display: flex; align-items: center; justify-content: center; position: relative; min-height: calc(100dvh + 80px) !important; height: calc(100dvh + 80px) !important; margin-top: -80px !important; overflow: hidden;"
  data-component-id="{{ componentId }}"
>
  <div class="ux-hero-characters" style="position: absolute; inset: 0; z-index: 2; width: 100%; height: 100%; opacity: 1; pointer-events: none; overflow: hidden;">
    <video
      class="ux-hero-video"
      src="/assets/video.mp4"
      autoplay
      muted
      loop
      playsinline
      webkit-playsinline
      preload="metadata"
      style="width: 100%; height: 100%; object-fit: cover; object-position: center center; filter: brightness(0.62) saturate(0.82) blur(1.2px); transform: none;"
    ></video>
  </div>

  <div class="container" style="max-width: 1200px; margin: 0 auto; text-align: center; position: relative; z-index: 10;">
    <div style="display: flex; flex-direction: column; align-items: center; gap: 2rem;">

      <div data-aos="fade-up" class="ux-hero-badge-wrap">
        <div style="display: inline-flex; align-items: center; justify-content: center; border: 1px solid rgba(34, 197, 94, 0.15); background-color: rgba(34, 197, 94, 0.1); border-radius: 9999px; font-size: 0.825rem; padding: 0.25rem 0.5rem; backdrop-filter: blur(16px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1);">
          <p style="display: inline-flex; align-items: center; justify-content: center; gap: 0.375rem; padding: 0.25rem 0.6rem; max-width: 28rem; color: rgba(74, 222, 128, 0.7); background-image: linear-gradient(to right, transparent, #4ade80, transparent); -webkit-background-clip: text; background-clip: text; background-repeat: no-repeat; background-size: var(--text-width, 200px) 100%; background-position: calc(-100% - var(--text-width, 200px)) 0; animation: textShine 8s infinite; filter: contrast(2); margin: 0;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#4ade80"><path d="M15.06 10.5a.75.75 0 0 0-1.12-1l-3.011 3.374l-.87-.974a.75.75 0 0 0-1.118 1l1.428 1.6a.75.75 0 0 0 1.119 0z"></path><path fill-rule="evenodd" d="M12 1.25c-.937 0-1.833.307-3.277.801l-.727.25c-1.481.506-2.625.898-3.443 1.23c-.412.167-.767.33-1.052.495c-.275.16-.55.359-.737.626c-.185.263-.281.587-.341.9c-.063.324-.1.713-.125 1.16c-.048.886-.048 2.102-.048 3.678v1.601c0 6.101 4.608 9.026 7.348 10.224l.027.011c.34.149.66.288 1.027.382c.387.1.799.142 1.348.142c.55 0 .96-.042 1.348-.142c.367-.094.687-.233 1.026-.382l.028-.011c2.74-1.198 7.348-4.123 7.348-10.224V10.39c0-1.576 0-2.792-.048-3.679a9 9 0 0 0-.125-1.16c-.06-.312-.156-.636-.34-.9c-.188-.266-.463-.465-.738-.625a9 9 0 0 0-1.052-.495c-.818-.332-1.962-.724-3.443-1.23l-.727-.25c-1.444-.494-2.34-.801-3.277-.801M9.08 3.514c1.615-.552 2.262-.764 2.92-.764s1.305.212 2.92.764l.572.196c1.513.518 2.616.896 3.39 1.21c.387.158.667.29.864.404q.144.084.208.139c.038.03.053.048.055.05a.4.4 0 0 1 .032.074q.03.082.063.248a7 7 0 0 1 .1.958c.046.841.046 2.015.046 3.624v1.574c0 5.176-3.87 7.723-6.449 8.849c-.371.162-.586.254-.825.315c-.228.059-.506.095-.976.095s-.748-.036-.976-.095c-.24-.06-.454-.153-.825-.315c-2.58-1.126-6.449-3.674-6.449-8.849v-1.574c0-1.609 0-2.783.046-3.624a7 7 0 0 1 .1-.958q.032-.166.063-.248c.018-.05.03-.07.032-.074a.4.4 0 0 1 .055-.05q.064-.055.208-.14c.197-.114.477-.245.864-.402c.774-.315 1.877-.693 3.39-1.21z" clip-rule="evenodd"></path></svg>
            <span>Trusted by 5000+ Satisfied Customers</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#4ade80"><path fill-rule="evenodd" d="M13.47 5.47a.75.75 0 0 1 1.06 0l6 6a.75.75 0 0 1 0 1.06l-6 6a.75.75 0 1 1-1.06-1.06l4.72-4.72H4a.75.75 0 0 1 0-1.5h14.19l-4.72-4.72a.75.75 0 0 1 0-1.06" clip-rule="evenodd"></path></svg>
          </p>
        </div>
      </div>

      <h1 class="ux-hero-title" data-aos="fade-up" data-aos-delay="100" style="margin-top: -0.5rem;">
        <span class="ux-gradient-text">{{ properties.title | renderString }}</span>
      </h1>

      {% if properties.subtitle %}
      <p class="ux-hero-subtitle" data-aos="fade-up" data-aos-delay="200">
        {{ properties.subtitle | renderString }}
      </p>
      {% endif %}

      <div style="display: flex; gap: 1rem; margin-top: -0.5rem; justify-content: center; flex-wrap: wrap;" data-aos="fade-up" data-aos-delay="250">
        {% if properties.cta and properties.cta_text %}
        <a href="{{ properties.cta | shopUrl }}" class="ux-hero-btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
          <span>{{ properties.cta_text }}</span>
        </a>
        {% endif %}
      </div>

      {% if properties.show_searchbar %}
      <div class="form-group fake-searchbar ux-searchbar" data-bs-toggle="modal" data-bs-target="#searchModal" role="button" data-aos="fade-up" data-aos-delay="300" style="display: none;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256"><path d="M229.66,218.34l-50.07-50.06a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.32ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"></path></svg>
        <input type="text" class="form-control" placeholder="Search for products..." readonly>
      </div>
      {% endif %}
    </div>
  </div>

  <div class="ux-scroll-arrow" onclick="window.scrollTo({top: window.innerHeight, behavior: 'smooth'})">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#D94A4A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </div>

  {% if properties.show_searchbar %}
  <div class="modal fade search-modal" id="searchModal" x-data="searchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <div class="form-group searchbar">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M229.66,218.34l-50.07-50.06a88.11,88.11,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.32ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"></path></svg>
            <input type="text" class="form-control" placeholder="Search for products..." x-model="searchTerm">
          </div>
        </div>
        <div class="modal-body">
          <div class="products">
            {% for item in sortedItems %}
              {% if item.type != 'group' %}
                <div
                  x-show="shouldShowItem($el)" 
                  x-transition
                  data-name="{{ item.name | lower | escape }}"
                >
                  {% render_snippet "product-card-horizontal.njk", product=item %}
                </div>
              {% else %}
                {% for product in item.products %}
                  <div
                    x-show="shouldShowItem($el)" 
                    x-transition
                    data-name="{{ product.name | lower | escape }}"
                  >
                    {% render_snippet "product-card-horizontal.njk", product=product %}
                  </div>
                {% endfor %}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
    document.querySelector('.search-modal').addEventListener('shown.bs.modal', function() {
      this.querySelector('.searchbar input').focus();
    });
  </script>
  {% endif %}
</section>
