{
    "templates": {
        "shop": {
            "layout": "master",
            "components": {
                "hero": {
                    "type": "hero",
                    "properties": {
                        "title": "The Marketplace built to be better.",
                        "subtitle": null,
                        "cta": "/#products",
                        "cta_text": "Explore Products",
                        "show_searchbar": false,
                        "show_feedback_rating": false,
                        "show_products_sold": false,
                        "show_total_customers": true,
                        "alignment": "center",
                        "height": "tall",
                        "background_image": null,
                        "side_image": null
                    }
                },
                "products": {
                    "type": "products",
                    "properties": {
                        "title": "Our Products",
                        "subtitle": "Browse our selection of premium products",
                        "trending_ids": [
                            "670139",
                            "661182",
                            "625265"
                        ]
                    }
                },
                "feedbacks": {
                    "type": "feedbacks",
                    "properties": {
                        "title": "Customer Reviews",
                        "subtitle": "See what our customers have to say",
                        "amount": 4
                    }
                },
                "features": {
                    "type": "features",
                    "properties": {
                        "title": "Why Choose Us?",
                        "subtitle": "Experience unmatched service quality. Our dedicated team is here around the clock to support you and simplify every step of the process.",
                        "items_per_row": 3,
                        "features": [
                            {
                                "title": "Customers around the world",
                                "description": "Users all over the world using our products.",
                                "icon": "fas fa-globe"
                            },
                            {
                                "title": "Safe & Undetected",
                                "description": "We provide the most secure and undetected products on the market.",
                                "icon": "fas fa-shield-alt"
                            },
                            {
                                "title": "Instant Delivery",
                                "description": "Experience instant key delivery after purchase.",
                                "icon": "fas fa-bolt"
                            },
                            {
                                "title": "24/7 Support",
                                "description": "We provide fast, responsive support — our team is always ready to help anytime.",
                                "icon": "fas fa-headset"
                            },
                            {
                                "title": "Easy Setup",
                                "description": "Our products are user-friendly and require no technical skills.",
                                "icon": "fas fa-cogs"
                            }
                        ]
                    }
                },
                "socials": {
                    "type": "socials",
                    "properties": {
                        "title": "Join Our Community",
                        "subtitle": null
                    }
                },
                "faq": {
                    "type": "faq",
                    "properties": {
                        "title": "Frequently Asked Questions",
                        "subtitle": "Got questions? We've got answers.",
                        "items": [
                            {
                                "question": "How do I receive my product?",
                                "answer": "After completing your purchase, your product will be delivered instantly to your email. You can also access it from your customer dashboard."
                            },
                            {
                                "question": "What payment methods do you accept?",
                                "answer": "We accept a variety of payment methods including credit/debit cards, PayPal, cryptocurrency, and more."
                            },
                            {
                                "question": "Your products is undetectable ?",
                                "answer": "Our products are continuously worked on by our developers to keep them undetected. However, using our software on a secondary account is highly recommended."
                            },
                            {
                                "question": "What if I need help or support?",
                                "answer": "Our support team is available 24/7. You can reach us through our Discord server or by opening a support ticket."
                            },
                            {
                                "question": "Can I get a refund?",
                                "answer": "Please refer to our refund policy page for detailed information regarding refunds and eligibility."
                            }
                        ]
                    }
                }
            },
